rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GROUP A: Collections whose document ID equals auth.uid ---

    // 1. users
    match /users/{userId} {
      allow read, create, update, delete: if request.auth != null &&
                                           request.auth.uid == userId;
    }

    // 2. userSettings
    match /userSettings/{userId} {
      allow read, create, update, delete: if request.auth != null &&
                                           request.auth.uid == userId;
    }

    // 3. notificationSettings
    match /notificationSettings/{userId} {
      allow read, create, update, delete: if request.auth != null &&
                                           request.auth.uid == userId;
    }

    // 4. userProgress
    match /userProgress/{userId} {
      allow read, create, update, delete: if request.auth != null &&
                                           request.auth.uid == userId;
    }


    // --- GROUP B: Collections with random document IDs ---

    // 5. habits
    match /habits/{habitId} {
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null &&
                                     resource.data.userId == request.auth.uid;
    }

    // 6. habitCompletions
    match /habitCompletions/{completionId} {
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null &&
                                     resource.data.userId == request.auth.uid;
    }

    // 7. journals
    match /journals/{entryId} {
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null &&
                                     resource.data.userId == request.auth.uid;
    }

    // 8. reminders
    match /reminders/{reminderId} {
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null &&
                                     resource.data.userId == request.auth.uid;
    }

    // 9. notifications
    match /notifications/{notificationId} {
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null &&
                                     resource.data.userId == request.auth.uid;
    }

    // 10. aiConversations
    match /aiConversations/{conversationId} {
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null &&
                                     resource.data.userId == request.auth.uid;
    }

    // 11. aiSummaries
    match /aiSummaries/{summaryId} {
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null &&
                                     resource.data.userId == request.auth.uid;
    }

    // 12. fcmTokens
    match /fcmTokens/{token} {
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null &&
                                     resource.data.userId == request.auth.uid;
    }
  }
}
