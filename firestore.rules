rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if the request matches the resource's owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. User Settings rules
    match /userSettings/{userId} {
      allow read, write: if isOwner(userId);
    }

    // 2. Habits rules
    match /habits/{habitId} {
      allow read, write: if isAuthenticated() && (
        resource == null || resource.data.userId == request.auth.uid
      ) && (
        request.resource == null || request.resource.data.userId == request.auth.uid
      );
    }

    // 3. Habit Completions rules
    match /habitCompletions/{completionId} {
      allow read, write: if isAuthenticated() && (
        resource == null || resource.data.userId == request.auth.uid
      ) && (
        request.resource == null || request.resource.data.userId == request.auth.uid
      );
    }

    // 4. Journal reflections rules
    match /journals/{entryId} {
      allow read, write: if isAuthenticated() && (
        resource == null || resource.data.userId == request.auth.uid
      ) && (
        request.resource == null || request.resource.data.userId == request.auth.uid
      );
    }

    // 5. Reminders & Alerts rules
    match /reminders/{reminderId} {
      allow read, write: if isAuthenticated() && (
        resource == null || resource.data.userId == request.auth.uid
      ) && (
        request.resource == null || request.resource.data.userId == request.auth.uid
      );
    }

    // 6. In-app Notifications logs rules
    match /notifications/{notificationId} {
      allow read, write: if isAuthenticated() && (
        resource == null || resource.data.userId == request.auth.uid
      ) && (
        request.resource == null || request.resource.data.userId == request.auth.uid
      );
    }

    // 7. AI conversations history rules
    match /aiConversations/{conversationId} {
      allow read, write: if isAuthenticated() && (
        resource == null || resource.data.userId == request.auth.uid
      ) && (
        request.resource == null || request.resource.data.userId == request.auth.uid
      );
    }

    // 8. Cached AI summaries rules
    match /aiSummaries/{summaryId} {
      allow read, write: if isAuthenticated() && (
        resource == null || resource.data.userId == request.auth.uid
      ) && (
        request.resource == null || request.resource.data.userId == request.auth.uid
      );
    }

    // 9. FCM Tokens rules
    match /fcmTokens/{token} {
      allow read, write: if isAuthenticated() && (
        resource == null || resource.data.userId == request.auth.uid
      ) && (
        request.resource == null || request.resource.data.userId == request.auth.uid
      );
    }

    // 10. Notification Settings rules
    match /notificationSettings/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
